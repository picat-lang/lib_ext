import aspic_runtime.

pp(A)=>foreach(X in A) println(X) end,println(-----------------------------------).
#define DIM 8
main=>N=DIM,asp
#const n = DIM.
% n-Queens encoding
{ q(I,1..n) } == 1 :- I = 1..n.
{ q(1..n,J) } == 1 :- J = 1..n.
:- { q(D-J,J) } >= 2, D = 2..2*n.
:- { q(D+J,J) } >= 2, D = 1-n..n-1.
end,
aspic_solve_sub(0),
pp([[q(I,J):J in 1..N]:I in 1..N])
.

